# Dependency directories
node_modules/

# Local build artifacts
# Note: js/firebase-config.js is normally generated by build.js. We committed a default version.
# If you want to prevent local builds from overwriting it in git, you can ignore it,
# but since it contains environment-specific values, it is best not to track the real credentials in git.
# Thus, we ignore firebase-config.js so developers do not accidentally commit their production Firebase secrets!
js/firebase-config.js

